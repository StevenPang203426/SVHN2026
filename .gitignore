# ============================================================
#  .gitignore — SVHN 街景字符识别项目
# ============================================================

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── 虚拟环境 ──
.venv/
venv/
env/
.env/
.python-version

# ── 数据集（体积大，不入库） ──

datasets/data
data
# ── 模型权重 ──
checkpoints/
runs/
*.pth
*.pt
*.onnx

# ── 日志与实验追踪 ──
logs/
wandb/
*.log

# ── 推理结果 ──
result*.csv

# ── IDE / 编辑器 ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Jupyter ──
.ipynb_checkpoints/

# ── 归档（旧代码，不入库） ──
archive/

# ── 系统文件 ──
__MACOSX/
